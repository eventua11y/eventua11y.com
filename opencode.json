{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.5",
  "small_model": "github-copilot/claude-haiku-4.3",
  "provider": {
    "github-copilot": {
      "options": {
        "setCacheKey": true
      }
    }
  },
  "agent": {
    "plan": {
      "model": "github-copilot/claude-opus-4.4"
    },
    "explore": {
      "model": "github-copilot/claude-haiku-4.3"
    },
    "lead": {
      "description": "Tech lead: decomposes tasks, delegates to coder/tester/accessibility, runs quality gates",
      "mode": "primary",
      "model": "github-copilot/claude-opus-4.4",
      "prompt": "{file:.agents/lead.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "npm run check": "allow",
          "npx tsc --noEmit": "allow"
        }
      }
    },
    "coder": {
      "description": "Developer: implements features across Astro, Vue, TypeScript, Sanity, Netlify edge functions, Supabase",
      "mode": "subagent",
      "model": "github-copilot/claude-sonnet-4.5",
      "prompt": "{file:.agents/coder.md}",
      "permission": {
        "bash": {
          "*": "ask",
          "npx tsc --noEmit": "allow",
          "npm run check": "allow"
        }
      }
    },
    "tester": {
      "description": "QA engineer: writes Playwright E2E and Vitest unit tests independently from the coder",
      "mode": "subagent",
      "model": "github-copilot/claude-sonnet-4.5",
      "prompt": "{file:.agents/tester.md}",
      "permission": {
        "bash": {
          "*": "ask",
          "npm run check": "allow",
          "npx playwright test *": "allow",
          "npx vitest run *": "allow"
        }
      }
    },
    "accessibility": {
      "description": "Accessibility specialist: assesses plans for WCAG risks and reviews implemented code; call early and late",
      "mode": "subagent",
      "model": "github-copilot/claude-sonnet-4.5",
      "prompt": "{file:.agents/accessibility.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "npx playwright test tests/accessibility.spec.ts*": "allow"
        }
      }
    },
    "security": {
      "description": "Security specialist: assesses plans for auth/data risks and reviews implemented code; call early and late on user-account work",
      "mode": "subagent",
      "model": "github-copilot/claude-sonnet-4.5",
      "prompt": "{file:.agents/security.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        }
      }
    }
  },
  "mcp": {
    "netlify": {
      "type": "local",
      "command": ["npx", "-y", "@netlify/mcp"]
    },
    "sanity": {
      "type": "remote",
      "url": "https://mcp.sanity.io",
      "oauth": {}
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {}
    },
    "astro-docs": {
      "type": "remote",
      "url": "https://mcp.docs.astro.build/mcp",
      "enabled": true
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=btzgjrkejhurcgmpaqzy",
      "oauth": {}
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"]
    }
  }
}
