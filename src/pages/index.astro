---
import DefaultLayout from '../layouts/default.astro';
import Today from '../components/Today.vue';
import EventList from '../components/EventList.vue';
import FilterBar from '../components/FilterBar.vue';
import Filters from '../components/Filters.vue';
import MonthNav from '../components/MonthNav.vue';
import StaticEventList from '../components/StaticEventList.astro';
import FilterBarPlaceholder from '../components/FilterBarPlaceholder.astro';

// Disable prerendering to enable SSR
export const prerender = false;

// Cache the response to reduce origin hits, matching the
// strategy used by the get-events edge function.
Astro.response.headers.set(
  'Cache-Control',
  'private, max-age=300, stale-while-revalidate=60'
);
---

<DefaultLayout>
  <Today client:load />
  <FilterBarPlaceholder />
  <FilterBar client:only="vue" />
  <Filters client:only="vue" />
  <div class="container grid">
    <div
      id="events"
      role="region"
      aria-labelledby="upcoming-events-heading"
      class="py-l readable main-content"
    >
      <h1 id="upcoming-events-heading" class="sr-only">
        Upcoming accessibility events
      </h1>
      <EventList type="upcoming" client:load />
      <noscript>
        <StaticEventList type="upcoming" />
      </noscript>
    </div>
    <MonthNav
      id="month-nav"
      class="mb-l"
      client:load
      contentRegion="#events"
      showTodayLink={true}
    />
  </div>
</DefaultLayout>
