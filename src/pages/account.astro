---
import Layout from '../layouts/default.astro';
import { createSupabaseServerClient } from '../lib/supabase/server';

const title = 'Your account';
const description = 'Manage your Eventua11y account.';

// Redirect to login if not authenticated
if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

const user = Astro.locals.user;
const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);

// Fetch profile data
const { data: profile } = await supabase
  .from('profiles')
  .select('display_name, avatar_url, preferences')
  .eq('id', user.id)
  .single();

const displayName =
  profile?.display_name ||
  user.user_metadata?.full_name ||
  user.user_metadata?.name ||
  '';
const avatarUrl =
  profile?.avatar_url || user.user_metadata?.avatar_url || '';
const email = user.email || '';
const provider = user.app_metadata?.provider || 'email';
const isEmailUser = provider === 'email';
---

<Layout title={title} description={description}>
  <div class="auth-page">
    <wa-card>
      <div class="wa-stack">
        <h1 class="wa-heading-l">Your account</h1>

        <div id="update-success" hidden>
          <wa-callout variant="success">
            <wa-icon slot="icon" name="circle-check" />
            Your profile has been updated.
          </wa-callout>
        </div>

        <div id="update-error" hidden>
          <wa-callout variant="danger">
            <wa-icon slot="icon" name="circle-exclamation" />
            <span id="update-error-message"
              >There was a problem updating your profile.</span
            >
          </wa-callout>
        </div>

        {
          avatarUrl && (
            <div class="account-avatar">
              <img
                src={avatarUrl}
                alt={`${displayName || 'User'}'s avatar`}
                width="80"
                height="80"
              />
            </div>
          )
        }

        <dl class="account-details">
          <dt>Email</dt>
          <dd>{email}</dd>
          <dt>Sign-in method</dt>
          <dd class="provider-name">
            {provider === 'github' && 'GitHub'}
            {provider === 'linkedin_oidc' && 'LinkedIn'}
            {provider === 'email' && 'Email and password'}
            {!['github', 'linkedin_oidc', 'email'].includes(provider) &&
              provider}
          </dd>
        </dl>

        <wa-divider></wa-divider>

        <h2 class="wa-heading-m">Edit profile</h2>

        <form id="profile-form" novalidate>
          <div class="wa-stack">
            <wa-input
              id="display-name"
              label="Display name"
              type="text"
              value={displayName}
              autocomplete="name"
            />
            <wa-button id="save-profile" type="submit">Save changes</wa-button>
          </div>
        </form>

        {
          isEmailUser && (
            <>
              <wa-divider />
              <h2 class="wa-heading-m">Change password</h2>
              <form id="password-form" novalidate>
                <div class="wa-stack">
                  <wa-input
                    id="new-password"
                    label="New password"
                    type="password"
                    autocomplete="new-password"
                    password-toggle
                  />
                  <wa-button id="save-password" type="submit">
                    Update password
                  </wa-button>
                </div>
              </form>
              <div id="password-success" hidden>
                <wa-callout variant="success">
                  <wa-icon slot="icon" name="circle-check" />
                  Your password has been updated.
                </wa-callout>
              </div>
              <div id="password-error" hidden>
                <wa-callout variant="danger">
                  <wa-icon slot="icon" name="circle-exclamation" />
                  <span id="password-error-message">
                    There was a problem updating your password.
                  </span>
                </wa-callout>
              </div>
            </>
          )
        }

        <wa-divider></wa-divider>

        <wa-button id="sign-out-button" appearance="outlined" variant="danger">
          Sign out
        </wa-button>
      </div>
    </wa-card>
  </div>
</Layout>

<script>
  import { createSupabaseBrowserClient } from '../lib/supabase/client';

  const supabase = createSupabaseBrowserClient();

  // Profile form
  const profileForm = document.getElementById(
    'profile-form',
  ) as HTMLFormElement;
  const displayNameInput = document.getElementById(
    'display-name',
  ) as HTMLInputElement & { value: string };
  const saveProfileButton = document.getElementById(
    'save-profile',
  ) as HTMLElement;
  const updateSuccess = document.getElementById(
    'update-success',
  ) as HTMLElement;
  const updateError = document.getElementById('update-error') as HTMLElement;
  const updateErrorMessage = document.getElementById(
    'update-error-message',
  ) as HTMLElement;

  profileForm?.addEventListener('submit', async (e: Event) => {
    e.preventDefault();
    updateSuccess.hidden = true;
    updateError.hidden = true;
    saveProfileButton.setAttribute('loading', '');

    const {
      data: { user },
    } = await supabase.auth.getUser();

    if (!user) {
      window.location.href = '/login';
      return;
    }

    const { error } = await supabase
      .from('profiles')
      .update({ display_name: displayNameInput.value })
      .eq('id', user.id);

    saveProfileButton.removeAttribute('loading');

    if (error) {
      updateErrorMessage.textContent =
        error.message || 'There was a problem updating your profile.';
      updateError.hidden = false;
    } else {
      updateSuccess.hidden = false;
    }
  });

  // Password form
  const passwordForm = document.getElementById(
    'password-form',
  ) as HTMLFormElement | null;
  const newPasswordInput = document.getElementById(
    'new-password',
  ) as (HTMLInputElement & { value: string }) | null;
  const savePasswordButton = document.getElementById(
    'save-password',
  ) as HTMLElement | null;
  const passwordSuccess = document.getElementById(
    'password-success',
  ) as HTMLElement | null;
  const passwordError = document.getElementById(
    'password-error',
  ) as HTMLElement | null;
  const passwordErrorMessage = document.getElementById(
    'password-error-message',
  ) as HTMLElement | null;

  passwordForm?.addEventListener('submit', async (e: Event) => {
    e.preventDefault();
    if (passwordSuccess) passwordSuccess.hidden = true;
    if (passwordError) passwordError.hidden = true;
    savePasswordButton?.setAttribute('loading', '');

    const password = newPasswordInput?.value;

    if (!password || password.length < 6) {
      if (passwordErrorMessage)
        passwordErrorMessage.textContent =
          'Password must be at least 6 characters.';
      if (passwordError) passwordError.hidden = false;
      savePasswordButton?.removeAttribute('loading');
      return;
    }

    const { error } = await supabase.auth.updateUser({ password });

    savePasswordButton?.removeAttribute('loading');

    if (error) {
      if (passwordErrorMessage)
        passwordErrorMessage.textContent =
          error.message || 'There was a problem updating your password.';
      if (passwordError) passwordError.hidden = false;
    } else {
      if (passwordSuccess) passwordSuccess.hidden = false;
      if (newPasswordInput) newPasswordInput.value = '';
    }
  });

  // Sign out
  document
    .getElementById('sign-out-button')
    ?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/login?signed-out=true';
    });
</script>
