---
export const prerender = false;

import Layout from '../layouts/default.astro';

const title = 'Set a new password';
const description = 'Choose a new password for your Eventua11y account.';
---

<Layout title={title} description={description}>
  <div class="auth-page">
    <wa-card>
      <form id="reset-password-form" class="wa-stack" novalidate>
        <h1 class="wa-heading-l">Set a new password</h1>

        <wa-input
          id="new-password"
          label="New password"
          type="password"
          required
          autocomplete="new-password"
          password-toggle
          ><span slot="hint"
            >Your new password must be at least 8 characters.</span
          ></wa-input
        >
        <wa-button id="reset-button" type="submit">Save new password</wa-button>

        <div id="reset-error-region" role="alert">
          <wa-callout id="reset-error" variant="danger" hidden tabindex="-1">
            <wa-icon slot="icon" name="circle-exclamation"></wa-icon>
            <span id="reset-error-message"
              >There was a problem resetting your password.</span
            >
          </wa-callout>
        </div>

        <div id="reset-success-region" role="status" aria-live="polite">
          <wa-callout id="reset-success" variant="success" hidden tabindex="-1">
            <wa-icon slot="icon" name="circle-check"></wa-icon>
            <strong>Password updated</strong><br />
            Your password has been changed. You can now log in with your new password.
          </wa-callout>
        </div>

        <p>
          <a href="/login">Back to log in</a>
        </p>
      </form>
    </wa-card>
  </div>
</Layout>

<script>
  import { createSupabaseBrowserClient } from '../lib/supabase/client';

  const supabase = createSupabaseBrowserClient();

  const form = document.getElementById(
    'reset-password-form'
  ) as HTMLFormElement;
  const passwordInput = document.getElementById(
    'new-password'
  ) as HTMLInputElement & { value: string };
  const resetButton = document.getElementById('reset-button') as HTMLElement;
  const resetError = document.getElementById('reset-error') as HTMLElement;
  const resetErrorMessage = document.getElementById(
    'reset-error-message'
  ) as HTMLElement;
  const resetSuccess = document.getElementById('reset-success') as HTMLElement;

  // Supabase sends the recovery token in the URL hash fragment.
  // The Supabase client library automatically picks it up from the
  // hash and exchanges it for a session via onAuthStateChange.
  // We wait for a PASSWORD_RECOVERY event before allowing the form
  // to submit.
  let recoverySessionReady = false;

  supabase.auth.onAuthStateChange((event) => {
    if (event === 'PASSWORD_RECOVERY') {
      recoverySessionReady = true;
    }
  });

  let isSubmitting = false;

  form?.addEventListener('submit', async (e: Event) => {
    e.preventDefault();
    if (isSubmitting) return;
    isSubmitting = true;
    resetError.hidden = true;
    resetSuccess.hidden = true;
    resetButton.setAttribute('loading', '');

    const password = passwordInput.value;

    if (!password || password.length < 8) {
      resetErrorMessage.textContent = 'Password must be at least 8 characters.';
      resetError.hidden = false;
      resetButton.removeAttribute('loading');
      passwordInput.focus();
      isSubmitting = false;
      return;
    }

    if (!recoverySessionReady) {
      resetErrorMessage.textContent =
        'This reset link is invalid or has expired. Please request a new one.';
      resetError.hidden = false;
      resetButton.removeAttribute('loading');
      resetError.focus();
      isSubmitting = false;
      return;
    }

    const { error } = await supabase.auth.updateUser({ password });

    resetButton.removeAttribute('loading');

    if (error) {
      resetErrorMessage.textContent =
        'There was a problem resetting your password. Please try again or request a new reset link.';
      resetError.hidden = false;
      resetError.focus();
      isSubmitting = false;
    } else {
      resetSuccess.hidden = false;
      resetSuccess.focus();
      // Disable the form after success
      passwordInput.setAttribute('disabled', '');
      resetButton.setAttribute('disabled', '');
      isSubmitting = false;
    }
  });
</script>
