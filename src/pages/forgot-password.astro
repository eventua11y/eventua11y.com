---
export const prerender = false;

import Layout from '../layouts/default.astro';

const title = 'Reset your password';
const description =
  'Request a password reset link for your Eventua11y account.';

// If already logged in, redirect to account page
if (Astro.locals.user) {
  return Astro.redirect('/account');
}
---

<Layout title={title} description={description}>
  <div class="auth-page">
    <wa-card>
      <form id="forgot-password-form" class="wa-stack" novalidate>
        <h1 class="wa-heading-l">Reset your password</h1>

        <p>
          Enter the email address you used to create your account and
          we&rsquo;ll send you a link to reset your password.
        </p>

        <wa-input
          id="email"
          label="Email"
          type="email"
          required
          autocomplete="email"></wa-input>
        <wa-button id="reset-button" type="submit">Send reset link</wa-button>

        <div id="forgot-error-region" role="alert">
          <wa-callout id="forgot-error" variant="danger" hidden tabindex="-1">
            <wa-icon slot="icon" name="circle-exclamation"></wa-icon>
            <span id="forgot-error-message"
              >There was a problem sending the reset link.</span
            >
          </wa-callout>
        </div>

        <div id="forgot-success-region" role="status" aria-live="polite">
          <wa-callout
            id="forgot-success"
            variant="success"
            hidden
            tabindex="-1"
          >
            <wa-icon slot="icon" name="circle-check"></wa-icon>
            <strong>Check your email</strong><br />
            If an account exists with that email address, we&rsquo;ve sent a password
            reset link. The link will expire in 1 hour.
          </wa-callout>
        </div>

        <p>
          <a href="/login">Back to log in</a>
        </p>
      </form>
    </wa-card>
  </div>
</Layout>

<script>
  import { createSupabaseBrowserClient } from '../lib/supabase/client';

  const supabase = createSupabaseBrowserClient();

  const form = document.getElementById(
    'forgot-password-form'
  ) as HTMLFormElement;
  const emailInput = document.getElementById('email') as HTMLInputElement & {
    value: string;
  };
  const resetButton = document.getElementById('reset-button') as HTMLElement;
  const forgotError = document.getElementById('forgot-error') as HTMLElement;
  const forgotErrorMessage = document.getElementById(
    'forgot-error-message'
  ) as HTMLElement;
  const forgotSuccess = document.getElementById(
    'forgot-success'
  ) as HTMLElement;

  let isSubmitting = false;

  form?.addEventListener('submit', async (e: Event) => {
    e.preventDefault();
    if (isSubmitting) return;
    isSubmitting = true;
    forgotError.hidden = true;
    forgotSuccess.hidden = true;
    resetButton.setAttribute('loading', '');

    const email = emailInput.value;

    if (!email) {
      forgotErrorMessage.textContent = 'Please enter your email address.';
      forgotError.hidden = false;
      resetButton.removeAttribute('loading');
      emailInput.focus();
      isSubmitting = false;
      return;
    }

    const { error } = await supabase.auth.resetPasswordForEmail(email, {
      redirectTo: `${window.location.origin}/reset-password`,
    });

    resetButton.removeAttribute('loading');

    if (error) {
      forgotErrorMessage.textContent =
        'There was a problem sending the reset link. Please try again.';
      forgotError.hidden = false;
      forgotError.focus();
    } else {
      // Always show success to prevent email enumeration
      forgotSuccess.hidden = false;
      forgotSuccess.focus();
    }
    isSubmitting = false;
  });
</script>
