---
import Logo from '../images/eventua11y_logo_wordmark_white.svg';
const currentPath = Astro.url.pathname;
const user = Astro.locals.user;
---

<header id="global-header" class="masthead">
  <div class="inner">
    <div class="masthead__logo">
      <a href="/" rel="home">
        <Logo class="logo" aria-label="Eventua11y" />
      </a>
    </div>
    <div class="masthead__actions">
      <nav class="primaryNav">
        <ul role="list" class="primaryNav__list">
          <li class="primaryNav__item">
            <a
              class="primaryNav__link"
              href="/past-events"
              aria-current={currentPath === '/past-events' ? 'page' : undefined}
            >
              Past Events
            </a>
          </li>
          <li class="primaryNav__item">
            <a
              class="primaryNav__link"
              href="/"
              aria-current={currentPath === '/' ? 'page' : undefined}
            >
              Upcoming
            </a>
          </li>
        </ul>
      </nav>
      {
        user ? (
          <a
            href="/account"
            class="masthead__account-link"
            aria-label="Your account"
          >
            <wa-icon name="circle-user" label="Your account" />
          </a>
        ) : (
          <a href="/login" class="masthead__account-link" aria-label="Log in">
            <wa-icon name="arrow-right-to-bracket" label="Log in" />
          </a>
        )
      }
      <wa-dropdown id="theme-selector" placement="bottom-end" distance="3">
        <wa-button
          slot="trigger"
          id="theme-selector-button"
          variant="brand"
          appearance="plain"
          ><wa-icon name="sun-bright" label="Light mode"></wa-icon></wa-button
        >
        <wa-dropdown-item type="checkbox" id="light-mode" value="light"
          >Light mode</wa-dropdown-item
        >
        <wa-dropdown-item type="checkbox" id="dark-mode" value="dark"
          >Dark mode</wa-dropdown-item
        >
        <wa-divider></wa-divider>
        <wa-dropdown-item
          type="checkbox"
          id="system-default"
          value="system"
          checked>System default</wa-dropdown-item
        >
      </wa-dropdown>
    </div>
  </div>
</header>
<!-- End #global-header -->
