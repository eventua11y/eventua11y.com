---
/**
 * Server-rendered event card for the <noscript> fallback.
 *
 * This is a simplified Astro version of Event.vue that renders
 * Schema.org-annotated HTML without any client-side interactivity.
 * It uses UTC dates since user timezone is unknown during SSR.
 */
import dayjs from 'dayjs';
import utc from 'dayjs/plugin/utc';
import localizedFormat from 'dayjs/plugin/localizedFormat';
import type { Event } from '../types/event';
import { formatDateRange } from '../utils/dateUtils';

dayjs.extend(utc);
dayjs.extend(localizedFormat);

interface Props {
  event: Event;
}

const { event } = Astro.props;

const isDeadline = event.type === 'deadline';
const isTheme = event.type === 'theme';
const isAllDay = event.day === true;
const isInternational = !event.timezone;

// CFS open check
const callForSpeakersOpen =
  event.callForSpeakers &&
  (!event.callForSpeakersClosingDate ||
    new Date() < new Date(event.callForSpeakersClosingDate));

// Machine-readable datetime formatting (UTC)
function formatDate(date: string, format: string): string {
  return dayjs.utc(date).format(format);
}

// Human-readable date range with locale-aware deduplication
// SSR uses UTC since user timezone is unknown
const formattedRange = formatDateRange({
  dateStart: event.dateStart,
  dateEnd: event.dateEnd,
  timezone: event.timezone,
  day: isAllDay,
  type: event.type,
  isDeadline,
  locale: 'en',
});

// Attendance mode display
const attendanceMode = event.attendanceMode || 'none';
const displayLocation = event.location || 'International';
---

{
  isDeadline ? (
    <div class="event event--deadline">
      <div class="event__dates">
        <time
          datetime={formatDate(event.dateStart, 'YYYY-MM-DDTHH:mm:ssZ')}
          itemprop="startDate"
          hidden
        />
        <span class="event__dateRange">
          {formattedRange}
          {!isInternational && ' UTC'}
        </span>
        {' '}
        <span class="badge badge--danger">Deadline</span>
      </div>
      <span class="event__title">
        Submit proposals for <a href={event.website}>{event.title}</a>
      </span>
    </div>
  ) : event.type ? (
    <article
      class={`event event--${event.type}`}
      itemscope
      itemtype="https://schema.org/Event"
      data-event-type={event.type}
    >
      <h3 class="event__title" itemprop="name">
        {event.website ? (
          <a href={event.website} itemprop="url">
            {event.title}
          </a>
        ) : (
          <span>{event.title}</span>
        )}
      </h3>

      {event.dateStart && (
        <div class="event__dates">
          <time
            datetime={formatDate(event.dateStart, 'YYYY-MM-DDTHH:mm:ssZ')}
            itemprop="startDate"
            hidden
          />
          {event.dateEnd && (
            <time
              datetime={formatDate(event.dateEnd, 'YYYY-MM-DDTHH:mm:ssZ')}
              itemprop="endDate"
              hidden
            />
          )}
          <span class="event__dateRange">
            {formattedRange}
            {!isInternational && ' UTC'}
          </span>
        </div>
      )}

      {attendanceMode !== 'none' && event.type !== 'deadline' && (
        <div class="event__delivery text-small">
          {attendanceMode === 'online' && (
            <span class="event__online">
              <meta
                itemprop="eventAttendanceMode"
                content="https://schema.org/OnlineEventAttendanceMode"
              />
              Online
            </span>
          )}
          {attendanceMode === 'offline' && (
            <span class="event__location">
              <meta
                itemprop="eventAttendanceMode"
                content="https://schema.org/OfflineEventAttendanceMode"
              />
              <span
                itemprop="location"
                itemscope
                itemtype="https://schema.org/Place"
              >
                {displayLocation}
              </span>
            </span>
          )}
          {attendanceMode === 'mixed' && (
            <div>
              <meta
                itemprop="eventAttendanceMode"
                content="https://schema.org/MixedEventAttendanceMode"
              />
              <span class="event__location">
                <span
                  itemprop="location"
                  itemscope
                  itemtype="https://schema.org/Place"
                >
                  {displayLocation}
                </span>
              </span>
              <span class="text-muted"> and </span>
              <span class="event__online">Online</span>
            </div>
          )}
        </div>
      )}

      {attendanceMode === 'none' && event.type !== 'deadline' && (
        <div class="event__delivery text-small">
          <span class="event__location">
            <span
              itemprop="location"
              itemscope
              itemtype="https://schema.org/Place"
            >
              {displayLocation}
            </span>
          </span>
        </div>
      )}

      {event.description && !isTheme && (
        <details class="event__children flow">
          <summary>Description</summary>
          <p class="event__description" itemprop="description">
            {event.description}
          </p>
        </details>
      )}

      {(callForSpeakersOpen || (event.isFree && !isTheme)) && (
        <div class="event__badges">
          {callForSpeakersOpen && (
            <span class="badge badge--success">Call for speakers</span>
          )}
          {event.isFree && !isTheme && <span class="badge">Free</span>}
        </div>
      )}
    </article>
  ) : null
}
